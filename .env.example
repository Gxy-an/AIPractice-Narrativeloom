# 小米 MiMo（推荐）
MIMO_API_KEY=your_mimo_api_key
OPENAI_API_KEY=your_mimo_api_key
OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
LLM_MODEL=mimo-v2-flash

# 网页访问密码（可选；留空则不启用）
APP_ACCESS_PASSWORD=your_access_password

